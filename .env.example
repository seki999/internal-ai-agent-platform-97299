# ローカル起動では外部サービスなしで動作する安全な初期値を利用します。
# 実credentialはこのファイルへ記載せず、必要な環境だけ `.env` または秘密管理基盤から渡します。

# Expressの公開portと、CORSで許可するFrontend origin。
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173

# memoryは単体起動用、postgresはDocker/Azure PostgreSQL接続用。
POSTGRES_REPOSITORY_MODE=memory
DATABASE_URL=postgresql://platform:platform@localhost:5432/ai_platform

# memoryはprocess内保存、httpはcosmosdb-mock serviceへの接続を表す。
COSMOS_REPOSITORY_MODE=memory
COSMOS_MOCK_URL=http://localhost:8090

# Azure実接続へ切り替える場合もkeyをGit管理せず、Managed Identityを優先する。
AZURE_AI_PROVIDER=mock
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_KEY=

# Browserから接続するBackend APIのbase URL。Vite build時に参照される。
VITE_API_BASE_URL=http://localhost:3001/api
